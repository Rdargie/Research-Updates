# 1. Load the professional toolkit
library(tidyverse)
library(rsample) # A crucial Tidyverse package for Machine Learning splits
# 2. Ingest the Real Historical Dataset
# I am pulling the actual Ashenfelter Bordeaux dataset directly from a public repository
data_url <- "[https://raw.githubusercontent.com/RamyArafa/The-Analytics-Edge-in-R/master/Week%201/wine.csv](https://raw.githubusercontent.com/RamyArafa/The-Analytics-Edge-in-R/master/Week%201/wine.csv)"
bordeaux_raw <- read_csv(data_url)
bordeaux_raw
bordeaux_raw <- read_csv(data_url)
# 3. Professional Data Wrangling & Feature Engineering
bordeaux_clean <- bordeaux_raw %>%
# Step A: Handle Missing Data
# Some recent vintages haven't been priced yet. We must remove them or our model will crash.
drop_na(Price) %>%
# Step B: Feature Engineering (Creating new predictive variables)
# In viticulture, older wines generally cost more. We engineer an 'Age' variable.
mutate(
Age = max(Year) - Year,
# Create a categorical variable to flag drought conditions during harvest
DryHarvest = if_else(HarvestRain < 100, "Yes", "No")
) %>%
# Step C: Select only the relevant features to prevent "Data Leakage"
select(Year, Price, AGST, WinterRain, HarvestRain, Age, DryHarvest)
